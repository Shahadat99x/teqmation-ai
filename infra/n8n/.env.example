# n8n local runtime
N8N_HOST=localhost
N8N_HOST_PORT=6061
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:6061
N8N_WEBHOOK_URL=http://localhost:6061
N8N_TIMEZONE=Europe/Vilnius

# Required secret for credentials and other encrypted n8n data
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string

# Dedicated Postgres for local n8n persistence
N8N_POSTGRES_DB=n8n
N8N_POSTGRES_USER=n8n
N8N_POSTGRES_PASSWORD=replace-with-a-strong-password
